# Normalize line endings to LF for text/source files so diffs stay clean
# across Windows/macOS/Linux contributors. Binary assets are left untouched.
* text=auto eol=lf

*.java   text eol=lf
*.kt     text eol=lf
*.gradle text eol=lf
*.xml    text eol=lf
*.md     text eol=lf
*.json   text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.sh     text eol=lf
*.pro    text eol=lf
*.properties text eol=lf

# Binary assets (never touch line endings)
*.png  binary
*.jpg  binary
*.jpeg binary
*.webp binary
*.gif  binary
*.ico  binary
*.ttf  binary
*.otf  binary
*.so   binary
*.jar  binary
*.aar  binary
*.keystore binary
*.zip  binary
*.tar.gz binary
*.meta4 binary
