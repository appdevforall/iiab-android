<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?android:attr/windowBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RadioGroup
            android:id="@+id/rg_sync_mode"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:background="@drawable/rounded_button"
            android:backgroundTint="#333333"
            android:layout_marginBottom="24dp">

            <RadioButton
                android:id="@+id/rb_mode_share"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/radio_selector_bg"
                android:button="@null"
                android:gravity="center"
                android:text="@string/sync_mode_share"
                android:textColor="@color/dash_text_primary"
                android:textStyle="bold"
                android:checked="true" />

            <RadioButton
                android:id="@+id/rb_mode_receive"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/radio_selector_bg"
                android:button="@null"
                android:gravity="center"
                android:text="@string/sync_mode_receive"
                android:textColor="@color/dash_text_secondary"
                android:textStyle="bold" />
        </RadioGroup>

        <LinearLayout
            android:id="@+id/container_share"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            tools:visibility="visible">

            <LinearLayout
                android:id="@+id/qr_display_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:visibility="gone"
                tools:visibility="visible">

                <FrameLayout
                    android:id="@+id/qr_card_container"
                    android:layout_width="220dp"
                    android:layout_height="220dp"
                    android:layout_marginBottom="16dp"
                    android:background="#FFFFFF"
                    android:padding="8dp">

                    <ImageView
                        android:id="@+id/img_qr_code"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/qr_content_description" />
                </FrameLayout>

                <RadioGroup
                    android:id="@+id/rg_network_selector"
                    android:layout_width="220dp"
                    android:layout_height="40dp"
                    android:orientation="horizontal"
                    android:background="@drawable/rounded_button"
                    android:backgroundTint="#333333"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <RadioButton
                        android:id="@+id/rb_net_wifi"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/radio_selector_bg"
                        android:button="@null"
                        android:gravity="center"
                        android:text="@string/wifi"
                        android:textColor="@color/dash_text_primary"
                        android:textStyle="bold"
                        android:checked="true" />

                    <RadioButton
                        android:id="@+id/rb_net_hotspot"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/radio_selector_bg"
                        android:button="@null"
                        android:gravity="center"
                        android:text="@string/hotspot"
                        android:textColor="@color/dash_text_secondary"
                        android:textStyle="bold" />
                </RadioGroup>

                <TextView
                    android:id="@+id/txt_share_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/sync_share_status_init"
                    android:textColor="#FF9800"
                    android:textSize="14sp"
                    android:textAlignment="center"
                    android:layout_marginBottom="24dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/card_share_system"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/rounded_button"
                android:backgroundTint="#222222"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/sync_card_title_system"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/sync_card_desc_system"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp" />

                <Button
                    android:id="@+id/btn_start_server"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="@string/sync_btn_start_server"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/rounded_button"
                    android:backgroundTint="#008000"
                    android:textAllCaps="false" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/card_share_apk"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/rounded_button"
                android:backgroundTint="#222222"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/sync_card_title_apk"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/sync_card_desc_apk"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp" />

                <Button
                    android:id="@+id/btn_share_app"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="@string/sync_btn_share_app"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/rounded_button"
                    android:backgroundTint="#0055A4"
                    android:textAllCaps="false" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/container_receive"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:visibility="gone"
            tools:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/rounded_button"
                android:backgroundTint="#222222"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/sync_card_title_receive"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/sync_card_desc_receive"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp" />

                <Button
                    android:id="@+id/btn_scan_qr"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="@string/sync_btn_scan_qr"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/rounded_button"
                    android:backgroundTint="#2196F3"
                    android:textAllCaps="false"
                    app:icon="@android:drawable/ic_menu_camera"
                    app:iconGravity="textStart" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/container_progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/rounded_button"
                android:backgroundTint="@color/dash_module_bg"
                android:padding="16dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/txt_transfer_filename"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/sync_transfer_filename"
                    android:textColor="@color/dash_text_primary"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <ProgressBar
                    android:id="@+id/progress_bar_transfer"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="0"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/txt_transfer_speed"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/sync_transfer_speed_default"
                        android:textColor="@color/dash_text_secondary"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/txt_transfer_eta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sync_transfer_eta_default"
                        android:textColor="@color/dash_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btn_cancel_transfer"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="16dp"
                    android:text="@string/sync_btn_cancel_transfer"
                    android:background="@drawable/rounded_button"
                    android:backgroundTint="#F44336"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textAllCaps="false" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>